# ── Chain ────────────────────────────────────────────────────────────────────
MONAD_RPC_URL=                      # required for live spot leg + registry writes
PERPL_CHAIN_ID=143                  # 143 mainnet | 10143 testnet
# PERPL_API_URL / PERPL_WS_URL / PERPL_EXCHANGE_ADDRESS default per chain id

# ── Hedger (paper by default) ────────────────────────────────────────────────
HEDGER_LIVE=false                   # true + all keys below = live
HEDGER_PRIVATE_KEY=                 # wallet: spot swaps + registry txs (operator-set)
PERPL_API_KEY=                      # from bun run hedger:enroll (or Perpl web UI)
PERPL_ED25519_PRIVKEY=              # 0x-hex 32B, printed by enroll
PERPL_ACCOUNT_ID=                   # from bun run hedger:bootstrap

HEDGER_MARKET=MON
HEDGER_NOTIONAL_USD=100
HEDGER_LEVERAGE=200                 # hundredths → 2x
HEDGER_CHURN_INTERVAL_MS=900000     # 15 min
HEDGER_CHURN_FRACTION=0.25
HEDGER_DELTA_SOFT_PCT=1
HEDGER_DELTA_HARD_PCT=3
HEDGER_FUNDING_SIGN=1               # flip if funding sign convention proves inverted
HEDGER_FUNDING_PAUSE_APR=10
HEDGER_FUNDING_RESUME_APR=5
HEDGER_MAX_DAILY_TAKER_USD=25
HEDGER_MAX_REPOSTS_PER_MIN=30
HEDGER_REGISTRY_ADDRESS=0x24BD952B9BaD090Eab24A1a91948fA130c8D3A48

# ── Spot leg (NullTerminal) ──────────────────────────────────────────────────
NT_API_BASE=https://api.nullterminal.xyz

# ── Alerts ───────────────────────────────────────────────────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=
